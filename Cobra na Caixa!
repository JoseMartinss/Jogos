#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <string.h>
#include <locale.h>

// função segura pra ler número, onde eu pesquisei tinha que bota isso em cima
int lerNumero(){
    int num;
    while(1){
        if(scanf("%d", &num) != 1){
            printf("Entrada invalida! Digite apenas numeros.\n");
            while(getchar() != '\n');
        } else {
            while(getchar() != '\n');
            return num;
        }
    }
}

int main(){

    setlocale(LC_ALL, "Portuguese");

    int escolha1, escolha2;
    int jogadorAtual;
    int caixa;
    int cobra, botao;
    int dnv;

    srand(time(NULL));

    do{

        int caixas[5] = {0}; 

        char nome1[50], nome2[50];

        printf("Escolha um nome:\n");
        printf("1 - robertinho do grau\n");
        printf("2 - geremias\n");
        printf("3 - steave\n");
        printf("4 - olavo de carvalho\n");
        printf("5 - jalin rabei\n");
        printf("6 - ronaldinho gaucho\n");
        printf("7 - 20comer 70correr\n");

        printf("\nJogador 1 escolha um numero: ");
        escolha1 = lerNumero();

        printf("Jogador 2 escolha um numero: ");
        escolha2 = lerNumero();

        switch(escolha1){
            case 1: strcpy(nome1,"robertinho do grau"); break;
            case 2: strcpy(nome1,"geremias"); break;
            case 3: strcpy(nome1,"steave"); break;
